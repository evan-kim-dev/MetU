# FastAPI backend — commit-safe template
# Copy to `.env` and fill values. Never commit real secrets.

APP_ENV=development
LOG_LEVEL=info

# Comma-separated browser origins allowed by CORSMiddleware.
# Local + Vercel production (add preview URLs explicitly if needed).
CORS_ORIGINS=http://localhost:3000,https://met-u.vercel.app

# Supabase (server / service role — NEVER expose to browser)
SUPABASE_URL=https://yfpvgxbmxgpjuzmpnbia.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Direct Postgres is optional (runtime uses Supabase SDK, not SQLAlchemy).
# Prefer Supavisor Transaction pooler on Render if you add direct DB access:
#   Dashboard → Connect → Transaction pooler → port 6543
# Session mode (5432) is fine for one-off migrations / db:push only.
DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.yfpvgxbmxgpjuzmpnbia
DB_PASSWORD=your_database_password
# npm run db:push 호환용 (DB_PASSWORD 와 동일 값)
# SUPABASE_DB_PASSWORD=your_database_password

# 앱 자체 JWT (향후 백엔드 인증용)
JWT_SECRET=change-me-to-a-long-random-string

# OpenRouter (primary LLM). OPENAI_* kept for backward compatibility.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_TIMEOUT_SECONDS=180
OPENROUTER_HTTP_REFERER=https://met-u.vercel.app
OPENROUTER_APP_TITLE=MetU

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT_SECONDS=180

# 공공데이터포털 — 인천국제공항 취항 항공사(B551177), 한국공항공사 공항코드(B551178) API
# https://www.data.go.kr 에서 API별 활용신청 후 발급 (일반 인증키 Decoding 값 권장)
DATA_GO_KR_SERVICE_KEY=your_data_go_kr_service_key

# Hotelbeds — 숙소 Content/Booking API (https://developer.hotelbeds.com)
# 테스트: https://api.test.hotelbeds.com / 상용: https://api.hotelbeds.com
HOTELBEDS_API_KEY=your_hotelbeds_api_key
HOTELBEDS_API_SECRET=your_hotelbeds_api_secret
HOTELBEDS_API_BASE=https://api.test.hotelbeds.com
