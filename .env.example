# Frontend (Next.js) — commit-safe template
# Copy to `.env.local` and fill values. Never commit real secrets.

# Browser-safe Supabase (RLS required)
NEXT_PUBLIC_SUPABASE_URL=https://yfpvgxbmxgpjuzmpnbia.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# FastAPI base URL for Next.js BFF (server-side only — no NEXT_PUBLIC_)
# Local:
BACKEND_URL=http://127.0.0.1:8000
# Vercel production example:
# BACKEND_URL=https://metu.onrender.com

# 카카오 REST API 키 (앱 관리 > 앱 키). 카카오계정과 함께 로그아웃에 사용
# NEXT_PUBLIC_KAKAO_REST_API_KEY=

# --- Supabase Kakao Auth (프로젝트: yfpvgxbmxgpjuzmpnbia) ---
# 1) Supabase Dashboard → Auth → Providers → Kakao
#    - Client ID  = 카카오 REST API 키
#    - Client Secret = 카카오 Client Secret (코드 ON 후 발급) ← 프론트 .env에 넣지 않음
# 2) Kakao Developers → 로그인 Redirect URI:
#    https://yfpvgxbmxgpjuzmpnbia.supabase.co/auth/v1/callback
# 3) Supabase → Auth → URL Configuration → Redirect URLs:
#    http://localhost:3000/auth/callback
#    https://met-u.vercel.app/auth/callback

# Do NOT put these in Next (browser):
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
#
# Server-only (Next API routes — no NEXT_PUBLIC_ prefix):
# SUPABASE_URL=https://yfpvgxbmxgpjuzmpnbia.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
