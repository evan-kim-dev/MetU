# Frontend (Next.js) — commit-safe template
# Copy to `.env.local` and fill values. Never commit real secrets.

# Browser-safe Supabase (RLS required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# FastAPI base URL for BFF proxy
BACKEND_URL=http://127.0.0.1:8000

# Kakao via Supabase Auth checklist:
# 1) Supabase Dashboard → Auth → Providers → Kakao (Client ID/Secret)
# 2) Kakao Developers Redirect URI:
#    https://YOUR_PROJECT.supabase.co/auth/v1/callback
# 3) Supabase Auth → URL Configuration Redirect URLs:
#    http://localhost:3000/auth/callback
#    https://YOUR_DOMAIN/auth/callback

# Do NOT put these in Next:
# OPENAI_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
